{
  "description": "Suggests /codex-review after significant code changes.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use-review.mjs\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
